{
  "manifest_version": 3,
  "name": "Video Subtitle Grabber",
  "version": "2.6.1",
  "description": "Lists media embedded on the current page and lets you save available subtitle/caption tracks for personal use.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": [
    "https://player.vimeo.com/*",
    "https://www.youtube.com/*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.js", "i18n.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
